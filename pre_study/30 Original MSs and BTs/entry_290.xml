<root main_tree_to_execute = "MainTree" >
	<!-- Paste your BT inside the following tag -->
	<BehaviorTree ID="MainTree">
	</BehaviorTree>
	
	<TreeNodesModel>
		<Ifprob>
			<input_port name="arg0" type="float"/>
			<input_port name="arg1" type="float"/>
			<input_port name="arg2" type="float"/>
		</Condition>
		<Ifsect>
			<input_port name="arg0" type="VectorPolar"/>
			<input_port name="arg1" type="float"/>
			<input_port name="arg2" type="float"/>
		</Condition>
		<Movcs>
			<output_port name="arg0" type="float"/>
			<input_port name="arg1" type="int"/>
		</Action>
		<Movcv>
			<output_port name="arg0" type="VectorPolar"/>
			<input_port name="arg1" type="int"/>
		</Action>
		<Movpv>
			<output_port name="arg0" type="VectorPolar"/>
			<input_port name="arg1" type="VectorPolar"/>
			<input_port name="arg2" type="int"/>
		</Action>
		<Mulas>
			<output_port name="arg0" type="float"/>
			<input_port name="arg1" type="float"/>
			<input_port name="arg2" type="float"/>
			<input_port name="arg3" type="float"/>
		</Action>
		<Mulav>
			<output_port name="arg0" type="VectorPolar"/>
			<input_port name="arg1" type="VectorPolar"/>
			<input_port name="arg2" type="float"/>
			<input_port name="arg3" type="VectorPolar"/>
		</Action>
		<Decorator ID="Repeati">
			<input_port name="arg0" type="int"/>
		</Decorator>
		<Rotav>
			<output_port name="arg0" type="VectorPolar"/>
			<input_port name="arg1" type="VectorPolar"/>
			<input_port name="arg2" type="int"/>
			<input_port name="arg3" type="VectorPolar"/>
		</Action>
	</TreeNodesModel>
</root>

