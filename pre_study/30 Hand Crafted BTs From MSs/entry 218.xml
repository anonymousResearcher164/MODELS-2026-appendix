<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 218">
    <Frequency frequency="1 Hz">
      <Fallback name="Failure">
        <Sequence>
          <Fallback>
            <CheckSameGoalAsBefore new_goal="new_goal"/>
            <Sequence>
              <RecoveryAction/>
              <ClearGlobalCostmapContext/>
              <ClearingLocalCostmapContext/>
              <WaitTime time="time"/>
            </Sequence>
          </Fallback>
          <ComputesPath name="GridBased"
                        goal="goal"/>
          <ClearGlobalCostmapContext/>
          <WhileDoElse>
            <FollowPath/>
            <ClearingLocalCostmapContext/>
          </WhileDoElse>
        </Sequence>
        <RetryUntilSuccessful num_attempts="10">
          <RecoveryAction/>
        </RetryUntilSuccessful>
      </Fallback>
    </Frequency>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckSameGoalAsBefore"
               editable="true">
      <input_port name="new_goal"/>
    </Condition>
    <Action ID="ClearGlobalCostmapContext"
            editable="true"/>
    <Action ID="ClearingLocalCostmapContext"
            editable="true"/>
    <Action ID="ComputesPath"
            editable="true">
      <input_port name="goal"/>
    </Action>
    <Action ID="FollowPath"
            editable="true"/>
    <Decorator ID="Frequency"
               editable="true">
      <input_port name="frequency"/>
    </Decorator>
    <Action ID="RecoveryAction"
            editable="true"/>
    <Action ID="WaitTime"
            editable="true">
      <input_port name="time"/>
    </Action>
  </TreeNodesModel>

</root>
