<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 25">
    <Repeat num_cycles="10">
      <Sequence>
        <Delay delay_msec="delayTime">
          <PoseDetection/>
        </Delay>
        <TracksObjects/>
        <SpinsToGetLocalized/>
        <Fallback name="GameNeedsInitialization">
          <Sequence>
            <CheckGameNeedsInitialization _description="Succesful -&gt; True -&gt; Game needs initalization&#10;Failure -&gt; False -&gt; Game needs no initilization"/>
            <InteractsWithHuman _description="Through speech and pose detection"/>
          </Sequence>
          <Sequence>
            <NavigateToSpesificLocation/>
            <InitiateGame/>
            <Sequence name="During the Game">
              <InstructPosesToHuman/>
              <CheckPosition ProvideFeedback="FeedbackOnPosition"/>
              <ConcludeGame/>
            </Sequence>
          </Sequence>
        </Fallback>
      </Sequence>
    </Repeat>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckGameNeedsInitialization"
               editable="true"/>
    <Condition ID="CheckPosition"
               editable="true">
      <output_port name="ProvideFeedback"/>
    </Condition>
    <Action ID="ConcludeGame"
            editable="true"/>
    <Action ID="InitiateGame"
            editable="true"/>
    <Action ID="InstructPosesToHuman"
            editable="true"/>
    <Action ID="InteractsWithHuman"
            editable="true"/>
    <Action ID="NavigateToSpesificLocation"
            editable="true"/>
    <Action ID="PoseDetection"
            editable="true"/>
    <Action ID="SpinsToGetLocalized"
            editable="true"/>
    <Action ID="TracksObjects"
            editable="true"/>
  </TreeNodesModel>

</root>
