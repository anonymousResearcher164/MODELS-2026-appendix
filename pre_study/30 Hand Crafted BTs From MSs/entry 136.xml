<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 136">
    <RepeatFrequency frequency="1 Hz">
      <Sequence>
        <UpdatingGoal/>
        <ComputingPath name="Using GridBased planner"/>
        <TurncatingComputedPath name="Up to the distance"
                                distance="distance"/>
        <KeepRunningUntilFailure>
          <FollowTruncatedPath/>
        </KeepRunningUntilFailure>
      </Sequence>
    </RepeatFrequency>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ComputingPath"
            editable="true"/>
    <Action ID="FollowTruncatedPath"
            editable="true"/>
    <Decorator ID="RepeatFrequency"
               editable="true">
      <input_port name="frequency"/>
    </Decorator>
    <Action ID="TurncatingComputedPath"
            editable="true">
      <input_port name="distance"/>
    </Action>
    <Action ID="UpdatingGoal"
            editable="true"/>
  </TreeNodesModel>

</root>
