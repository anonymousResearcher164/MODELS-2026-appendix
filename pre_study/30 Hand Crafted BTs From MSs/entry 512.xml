<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="PickDeliverCharge">
    <Sequence>
      <Fallback>
        <Inverter>
          <CheckVariantValue variant="pick"/>
        </Inverter>
        <SubTree ID="pick_subtree"/>
      </Fallback>
      <Fallback>
        <Inverter>
          <CheckVariantValue variant="deliver"/>
        </Inverter>
        <SubTree ID="deliver_subtree"/>
      </Fallback>
      <Fallback>
        <Inverter>
          <CheckVariantValue variant="charge"/>
        </Inverter>
        <SubTree ID="charge_subtree"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="charge_subtree">
    <Sequence>
      <MoveTo location="chargeLocation"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="deliver_subtree">
    <AlwaysSuccess/>
  </BehaviorTree>

  <BehaviorTree ID="entry 512">
    <ParallelAll max_failures="1">
      <EndlessRepeat>
        <VariantAction variant="variant"/>
      </EndlessRepeat>
      <Sequence>
        <SubTree ID="PickDeliverCharge"
                 variant="variant"/>
      </Sequence>
    </ParallelAll>
  </BehaviorTree>

  <BehaviorTree ID="pick_subtree">
    <AlwaysSuccess/>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckVariantValue"
               editable="true">
      <input_port name="variant"/>
    </Condition>
    <Decorator ID="EndlessRepeat"
               editable="true"/>
    <Action ID="MoveTo"
            editable="true">
      <input_port name="location"/>
    </Action>
    <SubTree ID="PickDeliverCharge"
             editable="true">
      <input_port name="variant"/>
    </SubTree>
    <Action ID="VariantAction"
            editable="true">
      <input_port name="variant"/>
    </Action>
  </TreeNodesModel>

</root>
