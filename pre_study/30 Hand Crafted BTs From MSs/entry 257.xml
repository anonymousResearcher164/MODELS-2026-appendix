<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MoveRobot">
    <MoveTo name="Nav2Client"
            goal="goal"/>
  </BehaviorTree>

  <BehaviorTree ID="entry 257">
    <Repeat num_cycles="3">
      <Sequence>
        <SubTree ID="MoveRobot"
                 goal="Goal_A"/>
        <SubTree ID="MoveRobot"
                 goal="Goal_B"/>
        <SubTree ID="MoveRobot"
                 goal="Goal_C"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <SubTree ID="MoveRobot"
             editable="true">
      <input_port name="goal"/>
    </SubTree>
    <Action ID="MoveTo"
            editable="true">
      <input_port name="goal"/>
    </Action>
  </TreeNodesModel>

</root>
