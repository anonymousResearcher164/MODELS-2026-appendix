<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 32 - navigate to Position">
    <Fallback>
      <Sequence name="Waypoints">
        <RetryUntilSuccessful num_attempts="numAttemps">
          <Fallback>
            <NavigateToPose location="waypoint"/>
            <Wait duration="duration"/>
          </Fallback>
        </RetryUntilSuccessful>
      </Sequence>
      <MarkedAsAchieved/>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="entry 32 - robot">
    <Sequence>
      <SubTree ID="entry 32 - navigate to Position"
               location="{waypoint_1}"/>
      <SubTree ID="entry 32 - navigate to Position"
               location="{waypoint_2}"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="MarkedAsAchieved"
            editable="true"/>
    <Action ID="NavigateToPose"
            editable="true">
      <input_port name="location"/>
    </Action>
    <Action ID="Wait"
            editable="true">
      <input_port name="duration"/>
    </Action>
  </TreeNodesModel>

</root>
