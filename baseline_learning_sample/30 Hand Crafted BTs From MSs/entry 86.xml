<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 86">
    <Repeat num_cycles="number_of_cycles">
      <Sequence>
        <Fallback>
          <CheckState name="CheckState against desired sequence"/>
          <ReplanAction/>
        </Fallback>
        <ReactiveSequence>
          <Fallback>
            <CheckLocomotionStatus/>
            <RecoveryAction/>
          </Fallback>
          <Fallback>
            <Move navigation_goal="navigation_goal"/>
            <Replanning/>
          </Fallback>
        </ReactiveSequence>
        <UpdateStatus name="Update state and desired sequence"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="CheckLocomotionStatus"
               editable="true"/>
    <Condition ID="CheckState"
               editable="true"/>
    <Action ID="Move"
            editable="true">
      <input_port name="navigation_goal"/>
    </Action>
    <Action ID="RecoveryAction"
            editable="true"/>
    <Action ID="ReplanAction"
            editable="true"/>
    <Action ID="Replanning"
            editable="true"/>
    <Action ID="UpdateStatus"
            editable="true"/>
  </TreeNodesModel>

</root>
