<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="MoveRobot">
    <Sequence>
      <MoveTo goal="goal"/>
      <TakeScreenshot client="ScreenshotClient"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="entry 198">
    <Repeat num_cycles="3">
      <Sequence>
        <SetValue goal="Goal A"
                  value="value"/>
        <SubTree ID="MoveRobot"
                 goal="Goal A"/>
        <SetValue goal="Goal B"
                  value="value"/>
        <SubTree ID="MoveRobot"
                 goal="Goal B"/>
        <SetValue goal="Goal C"
                  value="value"/>
        <SubTree ID="MoveRobot"
                 goal="Goal C"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <SubTree ID="MoveRobot"
             editable="true">
      <input_port name="goal"/>
    </SubTree>
    <Action ID="MoveTo"
            editable="true">
      <input_port name="goal"/>
    </Action>
    <Action ID="SetValue"
            editable="true">
      <input_port name="goal"/>
      <input_port name="value"/>
    </Action>
    <Action ID="TakeScreenshot"
            editable="true">
      <input_port name="client"/>
    </Action>
  </TreeNodesModel>

</root>
