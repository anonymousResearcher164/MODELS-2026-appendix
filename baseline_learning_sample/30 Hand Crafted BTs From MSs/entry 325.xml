<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 325">
    <Sequence>
      <ClearGlobalCostMap/>
      <SeekMultipleSearchPoses/>
      <RepeatUntilFailure>
        <Sequence>
          <NavigateToEachPose/>
          <CommunicatesSpeechMessage/>
          <SubTree ID="MoveRobot"
                   goal="next_goal"/>
          <CommunicateGoalSpeech/>
        </Sequence>
      </RepeatUntilFailure>
      <Fallback>
        <Sequence>
          <DetectPerson/>
          <Communicate message="Hi there! I found you!"/>
        </Sequence>
        <Sequence>
          <SpinAction/>
          <Communicate message="Hi there! I found you!"/>
        </Sequence>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ClearGlobalCostMap"
            editable="true"/>
    <Action ID="Communicate"
            editable="true">
      <output_port name="message"
                   default="Hi there! I found you!"/>
    </Action>
    <Action ID="CommunicateGoalSpeech"
            editable="true"/>
    <Action ID="CommunicatesSpeechMessage"
            editable="true"/>
    <Condition ID="DetectPerson"
               editable="true"/>
    <SubTree ID="MoveRobot"
             editable="true">
      <input_port name="goal"/>
    </SubTree>
    <Action ID="NavigateToEachPose"
            editable="true"/>
    <Decorator ID="RepeatUntilFailure"
               editable="true"/>
    <Action ID="SeekMultipleSearchPoses"
            editable="true"/>
    <Action ID="SpinAction"
            editable="true"/>
  </TreeNodesModel>

</root>
