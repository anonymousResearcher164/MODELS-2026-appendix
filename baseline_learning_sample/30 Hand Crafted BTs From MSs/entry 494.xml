<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 494">
    <Fallback name="Core_seq">
      <Sequence>
        <Fallback>
          <CheckMissionWait/>
          <StopVehicle/>
        </Fallback>
        <SetVehicleState/>
        <Fallback>
          <Inverter>
            <CheckCollision/>
          </Inverter>
          <StopVehicle/>
        </Fallback>
        <GeneratePath/>
        <Fallback>
          <Sequence>
            <Inverter>
              <CheckLangeChangeFeasibility/>
            </Inverter>
            <KeepLane/>
          </Sequence>
          <ChangeLane direction="right/left"/>
        </Fallback>
        <Fallback>
          <Inverter>
            <CheckProximity object="TrafficLight"/>
          </Inverter>
          <StopAtTrafficLight/>
        </Fallback>
        <Fallback>
          <Inverter>
            <CheckIrregularities/>
          </Inverter>
          <PublishData/>
        </Fallback>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ChangeLane"
            editable="true">
      <input_port name="direction"/>
    </Action>
    <Condition ID="CheckCollision"
               editable="true"/>
    <Condition ID="CheckIrregularities"
               editable="true"/>
    <Condition ID="CheckLangeChangeFeasibility"
               editable="true"/>
    <Condition ID="CheckMissionWait"
               editable="true"/>
    <Condition ID="CheckProximity"
               editable="true">
      <input_port name="object"/>
    </Condition>
    <Action ID="GeneratePath"
            editable="true"/>
    <Action ID="KeepLane"
            editable="true"/>
    <Action ID="PublishData"
            editable="true"/>
    <Action ID="SetVehicleState"
            editable="true"/>
    <Action ID="StopAtTrafficLight"
            editable="true"/>
    <Action ID="StopVehicle"
            editable="true"/>
  </TreeNodesModel>

</root>
