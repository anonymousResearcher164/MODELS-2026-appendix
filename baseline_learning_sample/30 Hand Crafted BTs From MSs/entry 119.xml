<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="entry 119">
    <Sequence>
      <Fallback>
        <EmergencyFinished/>
        <PromptUserInput name="Emergency finished?"
                         user_input="user_input"/>
      </Fallback>
      <Fallback>
        <RespondsY emergency_status="emergency_status"/>
        <ActionRequired/>
      </Fallback>
      <ProceedAccordingly/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ActionRequired"
            editable="true"/>
    <Condition ID="EmergencyFinished"
               editable="true"/>
    <Action ID="ProceedAccordingly"
            editable="true"/>
    <Action ID="PromptUserInput"
            editable="true">
      <input_port name="user_input"/>
    </Action>
    <Condition ID="RespondsY"
               editable="true">
      <output_port name="emergency_status"/>
    </Condition>
  </TreeNodesModel>

</root>
